{
	"framework": "vite",
	"buildCommand": "npm run build",
	"outputDirectory": "dist",
	"redirects": [
		{
			"source": "/Portfolio",
			"destination": "/",
			"permanent": true
		},
		{
			"source": "/Portfolio/:path*",
			"destination": "/:path*",
			"permanent": true
		}
	],
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/index.html"
		}
	]
}
